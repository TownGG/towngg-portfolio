/*
  X-Content-Type-Options: nosniff

/*.html
  Cache-Control: no-cache, max-age=0, must-revalidate

/
  Cache-Control: no-cache, max-age=0, must-revalidate

/assets/data/site-version.json
  Cache-Control: no-store, max-age=0

/assets/data/*.json
  Cache-Control: no-cache, max-age=0, must-revalidate

/assets/data/*.csv
  Cache-Control: no-cache, max-age=0, must-revalidate

/assets/css/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

/assets/icons/*
  Cache-Control: public, max-age=31536000, immutable
